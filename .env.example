# Copy to `.env` and fill in your own values, then `source .env` before running
# the scripts under contrib/*/deploy/. These substitute for the placeholders that
# appear in the deploy and profiling scripts.

# Private container registry that hosts your PyTorch-Native / vLLM-Neuron images,
# e.g. <aws-account-id>.dkr.ecr.<region>.amazonaws.com
export ECR_REGISTRY=

# Storage bucket holding the pre-converted model weights, e.g. an S3 bucket name.
export S3_MODEL_BUCKET=
