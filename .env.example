# Copy to `.env` and fill in only the values needed by the scripts you run.
# Qwen deploy scripts load this file automatically. ENV_FILE can select a
# different file.

# Storage bucket holding the pre-converted model weights, e.g. an S3 bucket name.
export S3_MODEL_BUCKET=

# Qwen3.6-27B vLLM-Neuron serving.
export QWEN27_VLLM_IMAGE=
export QWEN27_MODEL_DIR=
export QWEN27_EAGLE3_MODEL_DIR=
export QWEN27_VLLM_PLUGIN_DIR=
export QWEN27_COMPILE_CACHE_DIR=
export QWEN27_EAGLE3_COMPILE_CACHE_DIR=

# Qwen3.6-35B-A3B PyTorch-Native profiling.
export QWEN35_NATIVE_IMAGE=
export QWEN35_MODEL_DIR=
export QWEN35_NKILIB_DIR=
export QWEN35_PROFILE_ROOT=

# Qwen3.6-35B-A3B reusable compiler cache. The cache directory is the complete
# host directory mounted at /tmp in the Native container, not an individual NEFF.
export QWEN35_COMPILER_CACHE_DIR=
export QWEN35_COMPILER_CACHE_S3_URI=
export QWEN35_COMPILER_CACHE_S3_REGION=

# Optional location for the caller-scoped cross-compile platform-identity shim.
# The default is deploy/cross_compile/build/libnrt_platform_target_override.so.
export QWEN35_PLATFORM_TARGET_SHIM=
